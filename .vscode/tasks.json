    {
      "label": "Test BVH Exporter",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/exporter_bvh.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "Preview BVH Animation",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/bvh_previewer.py",
        "--list"
