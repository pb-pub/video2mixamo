{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Download Models",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "scripts/download_models.py"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Download Models - Lite",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "scripts/download_models.py",
        "lite"
      ],
      "problemMatcher": []
    },
    {
      "label": "Download Models - Heavy",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "scripts/download_models.py",
        "heavy"
      ],
      "problemMatcher": []
    },
    {
      "label": "Run with Webcam",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/main.py"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run with Webcam - No Preview",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/main.py",
        "--no-preview"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Run with Video File",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/main.py",
        "--input",
