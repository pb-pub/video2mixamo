        "--output",
        "animation_output.bvh"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Process Video with Smoothing",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/main.py",
        "--input",
        "",
        "--output",
        "animation_smooth.bvh"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Process Video - No Smoothing",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/main.py",
        "--input",
        "",
        "--output",
        "animation_raw.bvh",
        "--no-smooth"
      ],
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Test Filter Module",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/filter.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "Test Rotation Module",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/rotation.py"
      ],
      "problemMatcher": []
