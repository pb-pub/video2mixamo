    {
      "label": "Preview BVH Animation - Recent",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/bvh_previewer.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Help",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": [
        "src/main.py",
        "--help"
      ],
      "problemMatcher": []
